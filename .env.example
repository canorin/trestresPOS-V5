# ══════════════════════════════════════════════════════════════════
# Crumb — Variables de entorno requeridas
# ══════════════════════════════════════════════════════════════════
#
# Copiar este archivo a .env y completar los valores.
# .env NUNCA se commitea al repositorio (ya está en .gitignore).
#
# Generar valores seguros:
#   JWT_SECRET:             python -c 'import secrets; print(secrets.token_urlsafe(64))'
#   SUPER_ADMIN_PASSWORD:   python -c 'import secrets; print(secrets.token_urlsafe(24))'
#   CRUMBPOS_MASTER_KEY:    python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# ══════════════════════════════════════════════════════════════════

# ── Firma JWT (tokens de sesión) ──────────────────────────────────
# Obligatoria en producción. En desarrollo si no se define, se genera
# una clave aleatoria por arranque (las sesiones expiran al reiniciar).
JWT_SECRET=

# ── Super admin ───────────────────────────────────────────────────
# OBLIGATORIA siempre (el servidor no arranca sin este valor).
SUPER_ADMIN_EMAIL=matias@trestres.cl
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NOMBRE=Matías Bañados

# ── Cifrado de secretos en BD (Fernet) ───────────────────────────
# En desarrollo se usa data/.dev_master_key (generada automáticamente).
# En producción es OBLIGATORIA.
# CRUMBPOS_MASTER_KEY=

# ── Entorno ───────────────────────────────────────────────────────
# Dejar vacío o "development" para dev. Cambiar a "production" en
# el servidor — activa todos los fail-fast de seguridad.
# CRUMBPOS_ENV=production
